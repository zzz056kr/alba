# =====================================================================
# Dart / Flutter / Pub
# =====================================================================
**/.dart_tool/
**/.packages
**/.pub/
**/.pub-cache/
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/.last_build_id
**/build/
**/coverage/

# Symbolication / obfuscation
**/app.*.symbols
**/app.*.map.json

# =====================================================================
# Melos (workspace orchestrator)
# =====================================================================
# pubspec_overrides.yaml is auto-generated by `melos bootstrap` to point
# path dependencies at sibling packages. It changes per-machine, so we
# do not commit it.
**/pubspec_overrides.yaml
.melos_tool/

# =====================================================================
# iOS / macOS (Xcode)
# =====================================================================
**/Pods/
**/.symlinks/
**/Podfile.lock
**/xcuserdata/
**/*.xcuserstate
**/*.xcworkspace/xcuserdata/
**/DerivedData/

# =====================================================================
# Android (Gradle / IDE)
# =====================================================================
**/local.properties
**/.gradle/
**/captures/
**/android/app/debug/
**/android/app/profile/
**/android/app/release/
**/key.properties
**/*.jks
**/*.keystore

# =====================================================================
# IDE / Editor
# =====================================================================
.idea/
*.iml
*.ipr
*.iws
.vscode/
*.swp
*~
.history/

# =====================================================================
# OS junk
# =====================================================================
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# =====================================================================
# Build artifacts (release outputs)
# =====================================================================
*.apk
*.aab
*.ipa
*.app
*.dSYM.zip
*.dSYM

# =====================================================================
# Secrets / runtime config
# =====================================================================
# .env files are loaded as Flutter assets at runtime and may contain
# secrets. Only commit .env.example.
**/assets/config/.env

# =====================================================================
# Logs / misc
# =====================================================================
*.log
*.pyc
*.class
.atom/
.buildlog/
.svn/
.swiftpm/
migrate_working_dir/
