@baseUrl = http://localhost:8080
@ownerToken = REPLACE_OWNER_TOKEN
@staffToken = REPLACE_STAFF_TOKEN
@shopId = 1
@shopMemberId = 1
@attendanceId = 1
@scheduleId = 1

### 내 매장 목록 조회
GET {{baseUrl}}/shop/my
Authorization: Bearer {{ownerToken}}

### 매장 생성
POST {{baseUrl}}/shop
Authorization: Bearer {{ownerToken}}
Content-Type: application/json

{
  "name": "알바매장",
  "address": "서울시 강남구",
  "latitude": 37.4979,
  "longitude": 127.0276
}

### 매장 상세 조회
GET {{baseUrl}}/shop/{{shopId}}
Authorization: Bearer {{ownerToken}}

### 매장 수정
PUT {{baseUrl}}/shop/{{shopId}}
Authorization: Bearer {{ownerToken}}
Content-Type: application/json

{
  "name": "알바매장 수정",
  "address": "서울시 서초구",
  "latitude": 37.4910,
  "longitude": 127.0089,
  "status": "ACTIVE"
}

### QR 재발급
POST {{baseUrl}}/shop/{{shopId}}/qr/reissue
Authorization: Bearer {{ownerToken}}

### 매장 직원 목록 조회
GET {{baseUrl}}/shop/{{shopId}}/members?page=1&size=20&employmentTypes=REGULAR&statuses=PENDING
Authorization: Bearer {{ownerToken}}

### 수기 직원 등록
POST {{baseUrl}}/shop/{{shopId}}/members/manual
Authorization: Bearer {{ownerToken}}
Content-Type: application/json

{
  "name": "수기직원",
  "baseWage": 12000,
  "employmentType": "DAILY"
}

### 직원 승인 및 시급 세팅
PUT {{baseUrl}}/shop/{{shopId}}/members/{{shopMemberId}}/approve
Authorization: Bearer {{ownerToken}}
Content-Type: application/json

{
  "baseWage": 11000
}

### 스케줄 단건/반복 생성
POST {{baseUrl}}/shop/{{shopId}}/schedules
Authorization: Bearer {{ownerToken}}
Content-Type: application/json

{
  "shopMemberId": {{shopMemberId}},
  "workDate": "2026-05-06",
  "startTime": "09:00:00",
  "endTime": "18:00:00",
  "repeatUntil": "2026-05-31",
  "repeatDaysOfWeek": ["MONDAY", "WEDNESDAY", "FRIDAY"]
}

### 주간/월간 근무표 조회 - OWNER 전체
GET {{baseUrl}}/shop/{{shopId}}/schedules?viewType=MONTH&baseDate=2026-05-01
Authorization: Bearer {{ownerToken}}

### 주간/월간 근무표 조회 - 특정 직원 필터
GET {{baseUrl}}/shop/{{shopId}}/schedules?viewType=WEEK&baseDate=2026-05-05&shopMemberId={{shopMemberId}}
Authorization: Bearer {{ownerToken}}

### 근무표 조회 - STAFF 본인
GET {{baseUrl}}/shop/{{shopId}}/schedules?viewType=WEEK&baseDate=2026-05-05
Authorization: Bearer {{staffToken}}

### 등록된 스케줄 취소
DELETE {{baseUrl}}/shop/{{shopId}}/schedules/{{scheduleId}}
Authorization: Bearer {{ownerToken}}

### QR 출근
POST {{baseUrl}}/shop/{{shopId}}/attendances/clock-in/qr
Authorization: Bearer {{staffToken}}
Content-Type: application/json

{
  "qrCodeValue": "REPLACE_QR_UUID",
  "latitude": 37.4979,
  "longitude": 127.0276
}

### QR 퇴근
POST {{baseUrl}}/shop/{{shopId}}/attendances/clock-out/qr
Authorization: Bearer {{staffToken}}
Content-Type: application/json

{
  "qrCodeValue": "REPLACE_QR_UUID",
  "latitude": 37.4979,
  "longitude": 127.0276
}

### 일일 알바 빠른 생성 - 수기멤버 + 스케줄 + 출결
POST {{baseUrl}}/shop/{{shopId}}/daily-worker/quick-create
Authorization: Bearer {{ownerToken}}
Content-Type: application/json

{
  "name": "당일대타",
  "baseWage": 13000,
  "workDate": "2026-05-06",
  "startTime": "10:00:00",
  "endTime": "15:00:00"
}

### 출결/급여 이력 조회 - OWNER 전체
GET {{baseUrl}}/shop/{{shopId}}/attendances?page=1&size=20&startDate=2026-05-01&endDate=2026-05-31
Authorization: Bearer {{ownerToken}}

### 출결/급여 이력 조회 - STAFF 본인
GET {{baseUrl}}/shop/{{shopId}}/attendances?page=1&size=20&startDate=2026-05-01&endDate=2026-05-31
Authorization: Bearer {{staffToken}}

### 출결 수동 승인/수정
PUT {{baseUrl}}/shop/{{shopId}}/attendances/{{attendanceId}}
Authorization: Bearer {{ownerToken}}
Content-Type: application/json

{
  "clockInStatus": "EXCEPTION",
  "clockOutStatus": "NORMAL",
  "clockInAt": "2026-05-06T09:05:00",
  "clockOutAt": "2026-05-06T18:00:00",
  "authType": "MANUAL"
}
